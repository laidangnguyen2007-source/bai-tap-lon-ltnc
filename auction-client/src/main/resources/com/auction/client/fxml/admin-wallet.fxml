<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
  View: Quản Lý Ví (Admin)
  Controller tương ứng: AdminWalletController.java
-->
<BorderPane
  xmlns="http://javafx.com/javafx/21"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.auction.client.controller.AdminWalletController"
  styleClass="root-pane">

  <!-- Header -->
  <top>
    <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
      <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
      <Label text="🔧 Quản Lý Ví (Admin)" styleClass="app-title"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Button fx:id="refreshButton" text="🔄 Làm mới" onAction="#handleRefresh" styleClass="secondary-button"/>
      <Button fx:id="backButton" text="⬅ Quay lại" onAction="#handleBack" styleClass="secondary-button"/>
    </HBox>
  </top>

  <!-- Nội dung chia 2 cột -->
  <center>
    <HBox spacing="20">
      <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

      <!-- Cột trái: Form điều chỉnh số dư -->
      <VBox styleClass="info-card" spacing="14" prefWidth="380" minWidth="340">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <Label text="⚙ Điều Chỉnh Số Dư" styleClass="section-title"/>
        <Separator/>

        <GridPane hgap="12" vgap="12">
          <columnConstraints>
            <javafx.scene.layout.ColumnConstraints minWidth="100" prefWidth="100" halignment="LEFT"/>
            <javafx.scene.layout.ColumnConstraints hgrow="ALWAYS" minWidth="160"/>
          </columnConstraints>

          <Label text="User ID:" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
          <TextField fx:id="adjustUserIdField" promptText="Nhập ID người dùng..." styleClass="text-field"
                     GridPane.columnIndex="1" GridPane.rowIndex="0"/>

          <Label text="Số tiền (+/-):" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
          <TextField fx:id="adjustAmountField" promptText="VD: 500000 hoặc -200000" styleClass="text-field"
                     GridPane.columnIndex="1" GridPane.rowIndex="1"/>

          <Label text="Lý do:" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
          <TextField fx:id="adjustReasonField" promptText="Lý do điều chỉnh..." styleClass="text-field"
                     GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        </GridPane>

        <Label fx:id="adjustResultLabel" text="" styleClass="info-label" wrapText="true"/>

        <Button text="✅ Áp Dụng Điều Chỉnh" onAction="#handleAdjust" styleClass="primary-button"
                maxWidth="Infinity"/>
      </VBox>

      <!-- Cột phải: Bảng ví + bảng giao dịch -->
      <VBox HBox.hgrow="ALWAYS" spacing="12">

        <Label text="📊 Danh Sách Ví Người Dùng" styleClass="section-title"/>

        <TableView fx:id="walletTable" prefHeight="250" styleClass="data-table">
          <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
          </columnResizePolicy>
          <columns>
            <TableColumn fx:id="wUserIdCol" text="User ID" prefWidth="80"/>
            <TableColumn fx:id="wAvailableCol" text="Khả dụng" prefWidth="140"/>
            <TableColumn fx:id="wLockedCol" text="Đang khóa" prefWidth="140"/>
            <TableColumn fx:id="wTotalCol" text="Tổng" prefWidth="140"/>
          </columns>
          <placeholder>
            <Label text="Chưa tải được danh sách ví." styleClass="placeholder-label"/>
          </placeholder>
        </TableView>

        <Label text="📋 Nhật Ký Giao Dịch" styleClass="section-title"/>

        <TableView fx:id="txLogTable" VBox.vgrow="ALWAYS" styleClass="data-table">
          <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
          </columnResizePolicy>
          <columns>
            <TableColumn fx:id="logIdCol" text="Mã GD" prefWidth="60"/>
            <TableColumn fx:id="logUserIdCol" text="User ID" prefWidth="70"/>
            <TableColumn fx:id="logTypeCol" text="Loại" prefWidth="130"/>
            <TableColumn fx:id="logAmountCol" text="Số tiền" prefWidth="110"/>
            <TableColumn fx:id="logDescCol" text="Mô tả" prefWidth="180"/>
            <TableColumn fx:id="logTimeCol" text="Thời gian" prefWidth="150"/>
          </columns>
          <placeholder>
            <Label text="Chọn user để xem giao dịch." styleClass="placeholder-label"/>
          </placeholder>
        </TableView>
      </VBox>

    </HBox>
  </center>

</BorderPane>
