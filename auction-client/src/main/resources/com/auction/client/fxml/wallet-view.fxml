<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
  View: Quản Lý Ví (Bidder / Seller / Admin)
  Controller tương ứng: WalletViewController.java
-->
<BorderPane
  xmlns="http://javafx.com/javafx/21"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.auction.client.controller.WalletViewController"
  styleClass="root-pane">

  <!-- Header -->
  <top>
    <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
      <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
      <Label text="💰 Quản Lý Ví" styleClass="app-title"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Label fx:id="userInfoLabel" styleClass="welcome-label"/>
      <Button fx:id="refreshButton" text="🔄 Làm mới" onAction="#handleRefresh" styleClass="secondary-button"/>
      <Button fx:id="backButton" text="⬅ Quay lại" onAction="#handleBack" styleClass="secondary-button"/>
    </HBox>
  </top>

  <!-- Nội dung chính -->
  <center>
    <VBox spacing="16">
      <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

      <!-- Wallet Summary Panel -->
      <HBox spacing="20" styleClass="stats-container">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
           <Label text="Tổng Số Dư" styleClass="stat-label"/>
           <Label fx:id="totalBalanceLabel" text="0 VNĐ" styleClass="stat-value" style="-fx-text-fill: #3498db;"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
           <Label text="Số Dư Khả Dụng" styleClass="stat-label"/>
           <Label fx:id="availableBalanceLabel" text="0 VNĐ" styleClass="stat-value" style="-fx-text-fill: #2ecc71;"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
           <Label text="Đang Khóa" styleClass="stat-label"/>
           <Label fx:id="lockedBalanceLabel" text="0 VNĐ" styleClass="stat-value" style="-fx-text-fill: #e67e22;"/>
        </VBox>
      </HBox>

      <!-- Transaction History -->
      <Label text="📋 Lịch Sử Giao Dịch" styleClass="section-title"/>

      <TableView fx:id="transactionTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columnResizePolicy>
          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <columns>
          <TableColumn fx:id="txIdCol" text="Mã GD" prefWidth="60"/>
          <TableColumn fx:id="txTypeCol" text="Loại" prefWidth="140"/>
          <TableColumn fx:id="txAmountCol" text="Số tiền" prefWidth="120"/>
          <TableColumn fx:id="txDescCol" text="Mô tả" prefWidth="220"/>
          <TableColumn fx:id="txTimeCol" text="Thời gian" prefWidth="160"/>
        </columns>
        <placeholder>
          <Label text="Chưa có giao dịch nào." styleClass="placeholder-label"/>
        </placeholder>
      </TableView>

    </VBox>
  </center>

</BorderPane>
