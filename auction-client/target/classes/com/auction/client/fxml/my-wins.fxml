<?xml version="1.0" encoding="UTF-8"?>
 
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
 
<!--
  View: Màn hình Lịch Sử Thắng Cuộc
  Controller: MyWinsController.java
-->
<BorderPane
  xmlns="http://javafx.com/javafx/21"
  xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.auction.client.controller.MyWinsController"
  styleClass="root-pane"
  prefWidth="900" prefHeight="600">
 
  <top>
    <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
      <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
      <Button text="← Quay Lại" onAction="#handleBack" styleClass="secondary-button"/>
      <Label text="🏆 Những Phiên Bạn Đã Thắng" styleClass="app-title"/>
    </HBox>
  </top>
 
  <center>
    <VBox spacing="12">
      <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
 
      <Label text="Chúc mừng! Đây là danh sách các sản phẩm bạn đã đấu giá thành công." styleClass="field-label"/>
 
      <TableView fx:id="winsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columnResizePolicy>
          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
          <TableColumn fx:id="idColumn" text="Mã phiên" prefWidth="80"/>
          <TableColumn fx:id="itemNameColumn" text="Tên sản phẩm" prefWidth="250"/>
          <TableColumn fx:id="finalPriceColumn" text="Giá chốt (VNĐ)" prefWidth="180"/>
          <TableColumn fx:id="endTimeColumn" text="Ngày kết thúc" prefWidth="180"/>
          <TableColumn fx:id="statusColumn" text="Trạng thái" prefWidth="120"/>
        </columns>
        <placeholder>
          <Label text="Bạn chưa thắng phiên đấu giá nào. Hãy tiếp tục tham gia nhé!"/>
        </placeholder>
      </TableView>
    </VBox>
  </center>
 
</BorderPane>
